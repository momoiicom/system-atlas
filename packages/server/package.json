    "better-sqlite3": "^12.11.1",
    "elkjs": "^0.10.0",
    "fastify": "^5.1.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {"@types/better-sqlite3": "^7.6.12"}
}
